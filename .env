EXTENDED_MAINTENANCE=latest-em
CONTINUOUS_DELIVERY=latest-cd
LATEST_PREVIEW=latest-preview

IMAGE_IRIS_DEV_EM=containers.intersystems.com/intersystems/irishealth-community:$EXTENDED_MAINTENANCE
IMAGE_IRIS_DEV_CD=containers.intersystems.com/intersystems/irishealth-community:$CONTINUOUS_DELIVERY
IMAGE_IRIS_DEV_PREVIEW=containers.intersystems.com/intersystems/irishealth-community:$LATEST_PREVIEW

IMAGE_IRIS_DEV=${IMAGE_IRIS_DEV_PREVIEW}

DEV_DIR=/home/irisowner/dev

ISC_PACKAGE_IRISUSER=_SYSTEM
ISC_PACKAGE_IRISPWD=SYS

TZ=Europe/Paris

export VOLUME_PREFIX=$(basename "$PWD" | tr '[:upper:]' '[:lower:]')
VOLUME_NAME="${VOLUME_PREFIX}_"
